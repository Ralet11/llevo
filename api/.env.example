# Database
# Reemplaza USER y PASSWORD por credenciales reales de tu Postgres local o remoto.
DATABASE_URL="postgresql://USER:PASSWORD@localhost:5432/llevo_db"

# Server
PORT=3001
NODE_ENV=development

# Auth
JWT_SECRET=your_super_secret_key_here
JWT_EXPIRES_IN=7d
PHONE_DEFAULT_COUNTRY_CODE=+54
# Google Sign-In: client IDs validos como audiencia del id_token, separados por coma.
# Pega los 3 client IDs de Google Cloud (Web + Android + iOS) que crees en
# https://console.cloud.google.com -> APIs & Services -> Credentials.
GOOGLE_OAUTH_CLIENT_IDS=
EMAIL_AUTH_DELIVERY_MODE=log
RESEND_API_KEY=
RESEND_FROM_EMAIL=LLEVO <onboarding@tu-dominio.com>

# Twilio Verify (OTP por telefono)
TWILIO_VERIFY_SERVICE_SID=
TWILIO_VERIFY_CHANNEL=sms
TWILIO_API_KEY_SID=
TWILIO_API_KEY_SECRET=
# Alternativa para desarrollo local si no usas API Keys:
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=

# Didit (verificacion de conductores)
DIDIT_API_KEY=
DIDIT_WORKFLOW_ID=
DIDIT_API_BASE_URL=https://verification.didit.me/v3
DIDIT_BYPASS_VERIFICATION=false
# Fallback si no envias callbackUrl desde la app.
DIDIT_CALLBACK_URL=llevo://driver/verify
# Se obtiene al crear el destino webhook en Didit.
DIDIT_WEBHOOK_SECRET=
# Endpoint publico a registrar en Didit:
# https://tu-backend.com/api/v1/drivers/verification/webhook

# CORS
CORS_ORIGIN=http://localhost:3000

# Payments (Mercado Pago)
MP_ACCESS_TOKEN=
MP_PUBLIC_KEY=
PLATFORM_FEE_PERCENT=12
