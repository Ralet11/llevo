EXPO_PUBLIC_API_URL=http://192.168.1.36:3001/api/v1
# El backend debe quedar accesible desde el telefono y tener configurado Twilio + Didit.
# Google Maps se consume desde el backend (api/.env), no desde la app mobile.
EXPO_PUBLIC_DEFAULT_MAP_LAT=-34.6037
EXPO_PUBLIC_DEFAULT_MAP_LNG=-58.3816
EXPO_PUBLIC_DEFAULT_MAP_DELTA=0.035

# Google Sign-In (client IDs de Google Cloud -> APIs & Services -> Credentials).
# Crealos como "OAuth client ID" del tipo correspondiente. Si faltan, el boton
# de Google queda como "Pronto". scheme=llevo, package/bundle=com.llevo.app.
EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID=
# Android: tipo "Android", con package com.llevo.app + SHA-1 del build (eas credentials).
EXPO_PUBLIC_GOOGLE_ANDROID_CLIENT_ID=
# iOS: tipo "iOS", con bundle id com.llevo.app.
EXPO_PUBLIC_GOOGLE_IOS_CLIENT_ID=
